# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me-in-production

# ─── Storage provider ─────────────────────────────────────
# Default: local JSON at .local/enterprise-db/sproutdrive.json
# With Firebase vars below → cloud sync to Firestore (enterprise)

# Pure in-memory (demos only — data lost on restart)
# USE_MEMORY_STORAGE=true

# PostgreSQL (legacy Replit / Neon)
# STORAGE_PROVIDER=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/sproutdrive

# Seed sample data when local DB file is new (default: true)
# SEED_SAMPLE_DATA=false

# ─── Firebase Firestore — sproutdrive-a975e ───────────────
# Console: https://console.firebase.google.com/project/sproutdrive-a975e/firestore
# Setup guide: docs/FIREBASE_SETUP.md

FIREBASE_PROJECT_ID=sproutdrive-a975e
FIREBASE_ORG_ID=default

# Download service account JSON from Firebase Console → save here:
FIREBASE_SERVICE_ACCOUNT_PATH=./.local/firebase-service-account.json

# Alternative for CI/cloud deploy (entire JSON on one line):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"sproutdrive-a975e",...}

# ─── Replit Auth (production on Replit only) ──────────────
# REPL_ID=
# ISSUER_URL=https://replit.com/oidc
